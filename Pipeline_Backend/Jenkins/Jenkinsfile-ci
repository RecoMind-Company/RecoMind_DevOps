        stage("SonarQube Analysis") {
            agent {
                kubernetes {
                    yaml """
        apiVersion: v1
        kind: Pod
        spec:
          containers:
          - name: dotnet
            image: mcr.microsoft.com/dotnet/sdk:8.0
            command: ["cat"]
            tty: true
          - name: java
            image: eclipse-temurin:17-jdk
            command: ["cat"]
            tty: true

            volumeMounts:
            - name: nuget-cache
              mountPath: /nuget-cache

          volumes:
          - name: nuget-cache
            emptyDir: {}
        """
                }
            }

            steps {
                container('dotnet') {
                    unstash 'source'

                    withCredentials([string(credentialsId: 'sonarCloud', variable: 'SONAR_TOKEN')]) {

                        script {

                            // install once فقط
                            sh '''
                                dotnet tool install --global dotnet-sonarscanner || true
                                export PATH="$PATH:/root/.dotnet/tools"
                                export SONAR_USER_HOME=$WORKSPACE/.sonar
                                mkdir -p $SONAR_USER_HOME
                            '''

                            def serviceList = services.toList()

                            for (serviceName in serviceList) {

                                echo "🔍 Sonar for ${serviceName}"

                                sh """
                                export PATH="\$PATH:/root/.dotnet/tools"
                                

                                cd ${SERVICES_DIR}/${serviceName}

                                sln=\$(find . -name "*.sln" | head -n 1)

                                if [ -z "\$sln" ]; then
                                    echo "No sln found"
                                    exit 1
                                fi

                                dotnet sonarscanner begin \
                                /k:"recomind-${serviceName}" \
                                /o:"recomind-company" \
                                /d:sonar.host.url="https://sonarcloud.io" \
                                /d:sonar.token="\$SONAR_TOKEN"

                                dotnet build "\$sln" -c Release --no-restore

                                dotnet sonarscanner end \
                                /d:sonar.token="\$SONAR_TOKEN"
                                """

                                echo "✅ Done: ${serviceName}"
                            }
                        }
                    }
                }
            }
        }

        stage('Achieve Services List') {
            
            steps {
                    writeFile file: 'services.txt', text: services.join('\n')
                    archiveArtifacts artifacts: 'services.txt', allowEmptyArchive: true
            }
        }

       stage("Build And Push Image using (kaniko)"){
    agent {
        kubernetes {
            yaml """
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: kaniko
                image: gcr.io/kaniko-project/executor:debug
                command:
                - /busybox/sh
                args:
                - -c
                - |
                   /busybox/cat
                tty: true
                workingDir: /workspace
                resources:
                  requests:
                    cpu: "500m"
                    memory: "1Gi"
                  limits:
                    cpu: "1500m"
                    memory: "4Gi"
            """
        }
    }
    steps {
        container('kaniko') {
            unstash 'source'

            withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                sh '''
                    # إنشاء ملف الإعدادات في المسار الافتراضي لـ Kaniko
                    mkdir -p /kaniko/.docker
                    AUTH=$(echo -n "${DOCKER_USER}:${DOCKER_PASS}" | base64)
                    cat > /kaniko/.docker/config.json <<EOF
{
  "auths": {
    "https://index.docker.io/v1/": {
      "auth": "$AUTH"
    }
  }
}
EOF
                    echo "✅ Docker config.json created"
                '''
                
                script {
                    def serviceList = services.toList()
                    for (int i = 0; i < serviceList.size(); i++) {
                        def serviceName = serviceList[i]
                        def cleanImageName = "${IMAGE_NAME}-${serviceName.toLowerCase()}".replace("_", "-")
                        def imageTag = "${cleanImageName}:${TAG}"

                        echo "🚀 Building (${i+1}/${serviceList.size()}) for ${serviceName}"
                        
                        try {
                            sh """
                                /kaniko/executor \
                                --context ./${SERVICES_DIR}/${serviceName} \
                                --dockerfile ./${SERVICES_DIR}/${serviceName}/Dockerfile \
                                --destination ${imageTag} \
                                --cache=true \
                                --cache-repo=${IMAGE_NAME}-cache \
                                --cache-ttl=24h \
                                --snapshot-mode=redo \
                                --use-new-run \
                                --cleanup \
                                --compressed-caching=false \
                                --verbosity=info
                            """
                            echo "✅ Successfully built and pushed ${imageTag}"
                        } catch (Exception e) {
                            echo "❌ Build failed for ${serviceName}: ${e.message}"
                        }
                    }
                }
            }
        }
    }
}












        stage('Prepare Trivy Template') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    sh '''
                        mkdir -p trivy-templates
                        wget -q https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -O trivy-templates/html.tpl

                    '''
                    stash name: 'trivy-tpl', includes: 'trivy-templates/html.tpl'
                }
            }
        }

stage('Trivy Security Scan') {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: trivy
    image: aquasec/trivy:latest
    command: ["cat"]
    tty: true
    resources:
      requests:
        memory: "1.5Gi"  # رامات أكتر شوية لضمان الاستقرار
        cpu: "500m"
    volumeMounts:
    - name: workspace-volume
      mountPath: /home/jenkins/agent
  volumes:
  - name: workspace-volume
    emptyDir: {}
"""
        }
    }
    steps {
        container('trivy') {
            script {
                echo "📥 Downloading Trivy DB once..."
                sh "trivy image --download-db-only"

                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', usernameVariable: 'T_USER', passwordVariable: 'T_PASS')]) {
                    for (service in services) {
                        def serviceName = service
                        def imageTag = "redasaad1234/backend-${serviceName.toLowerCase()}:${TAG}"
                        
                        echo "🔍 Scanning: ${serviceName} ..."
                        
                        sh '''
                            export TRIVY_USERNAME=''' + "${T_USER}" + '''
                            export TRIVY_PASSWORD=''' + "${T_PASS}" + '''
                            
                            # 1. التأكد من وجود الفولدر ونزول الـ Template جوه الـ Pod الحالي
                            mkdir -p trivy-templates
                            if [ ! -f trivy-templates/html.tpl ]; then
                                wget -q https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -O trivy-templates/html.tpl
                            fi

                            # 2. تشغيل الفحص
                            trivy image --no-progress --scanners vuln --severity HIGH,CRITICAL \
                                --format template --template @trivy-templates/html.tpl \
                                -o trivy-''' + "${serviceName}.html ${imageTag}" + '''
                        '''
                    }
                }
                archiveArtifacts artifacts: "trivy-*.html"
            }
        }
    }
}

