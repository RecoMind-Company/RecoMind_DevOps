        stage('Prepare Trivy Template') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    sh '''
                        mkdir -p trivy-templates
                        wget -q https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -O trivy-templates/html.tpl

                    '''
                    stash name: 'trivy-tpl', includes: 'trivy-templates/html.tpl'
                }
            }
        }

        stage('Trivy Security Scan') {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: trivy
    image: aquasec/trivy:latest
    command: ["cat"]
    tty: true
    resources:
      requests:
        memory: "1Gi"   # زودنا الرامات شوية عشان الفحص
        cpu: "500m"
    volumeMounts:
    - name: workspace-volume
      mountPath: /home/jenkins/agent
  volumes:
  - name: workspace-volume
    emptyDir: {}
"""
        }
    }
    steps {
        container('trivy') {
            script {
                // 1. تحميل قاعدة البيانات مرة واحدة فقط للكل
                echo "📥 Downloading Trivy DB once..."
                sh "trivy image --download-db-only"

                // 2. معالجة السيرفس بمعدل هادئ (مثلاً 2 في المرة)
                int maxParallel = 2 
                def chunks = services.collate(maxParallel)

                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', usernameVariable: 'T_USER', passwordVariable: 'T_PASS')]) {
                    for (chunk in chunks) {
                        def trivySteps = [:]
                        for (service in chunk) {
                            def serviceName = service
                            def imageTag = "redasaad1234/backend-${serviceName.toLowerCase()}:${TAG}"
                            
                            trivySteps["Scan ${serviceName}"] = {
                                sh """
                                    export TRIVY_USERNAME='${T_USER}'
                                    export TRIVY_PASSWORD='${T_PASS}'
                                    
                                    # نستخدم Cache dir منفصل بس الـ DB موحدة
                                    export TRIVY_CACHE_DIR="/tmp/trivy-cache-${serviceName}"
                                    
                                    trivy image --no-progress --severity HIGH,CRITICAL \
                                        --format template --template @trivy-templates/html.tpl \
                                        -o trivy-${serviceName}.html ${imageTag}
                                """
                            }
                        }
                        parallel trivySteps
                    }
                }
                archiveArtifacts artifacts: "trivy-*.html"
            }
        }
    }
