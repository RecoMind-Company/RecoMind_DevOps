pipeline{
    agent any

    environment {
        DOCKERHUB = credentials('Docker_Hub_Backend')          // credentials من Jenkins (username/password)
        SONAR_TOKEN = credentials('sonarCloud')  // token SonarQube
        IMAGE_NAME = "redasaad1234/backend"
        DEPENDENCY_CHECK_DATA = "/var/jenkins_home/caches/dependency-check"
        TAG = "latest"
        SERVICES_DIR = "Microservices"  // Updated path
        NVD_API_KEY = credentials('nvd-api-key-id')
        NUGET_PACKAGES = "/nuget-cache"
        }

    stages {

        
        stage("checkout Source code") {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/RecoMind-Company/RecoMind-Backend.git',
                        credentialsId: 'Git_hub'
                    ]],
                    extensions: [
                        [$class: 'PruneStaleBranch']  
                    ]
                ])

                stash name: 'source', includes: '**/*'
            }

            post {
                always {
                    cleanWs()   // ✅ صح هنا
                }
            }
        }
        stage('Discover Microservices') {
            
            steps {
                unstash 'source'   
                script {
                    // Debug: List what's in the workspace
                    sh "echo '📁 Contents of workspace:' && pwd && ls -la"
                    
                    // Check if SERVICES_DIR exists
                    sh """
                        if [ -d "${SERVICES_DIR}" ]; then
                            echo "✅ ${SERVICES_DIR} found"
                            ls -d ${SERVICES_DIR}/*/ 2>/dev/null || echo "⚠️ No subdirectories found in ${SERVICES_DIR}"
                        else
                            echo "❌ ${SERVICES_DIR} not found! Listing available directories..."
                            ls -la
                            exit 1
                        fi
                    """
                    
                    // Discover services
                    services = sh(
                        script: "ls -d ${SERVICES_DIR}/*/ 2>/dev/null | xargs -n 1 basename || echo ''",
                        returnStdout: true
                    ).trim().split("\n").findAll { it != '' }

                    if (services.isEmpty() || services[0] == '') {
                        echo "⚠️ No services found! Check repository structure."
                        services = []
                    } else {
                        echo "🔍 Found services: ${services}"
                    }
                }
                
            }
        }

        stage("Restore"){
            agent {
                kubernetes {
                    yaml """
            apiVersion: v1
            kind: Pod
            spec:
            volumes:
            - name: nuget-cache
                emptyDir: {}

            containers:
            - name: dotnet
                image: mcr.microsoft.com/dotnet/sdk:8.0
                command: ["cat"]
                tty: true
                volumeMounts:
                - name: nuget-cache
                mountPath: /nuget-cache
            """
                }
            }

            steps {
                container('dotnet') {
                    unstash 'source'

                    script {
                        def serviceList = services.toList()
                        int maxParallel = 3
                        def chunks = serviceList.collate(maxParallel)

                        withEnv([
                            "NUGET_PACKAGES=/nuget-cache",
                        ]) {

                            // مهم جدًا: إنشاء فولدر الكاش
                            sh "mkdir -p /nuget-cache"

                            int groupIndex = 1

                            for (chunk in chunks) {
                                echo "➡️ Restoring group ${groupIndex}/${chunks.size()} in parallel..."

                                def restoreSteps = [:]

                                for (service in chunk) {
                                    def serviceName = service

                                    restoreSteps["Restore ${serviceName}"] = {
                                        sh """
                                            set -e

                                            cd ${SERVICES_DIR}/${serviceName}

                                            sln=\$(find . -name "*.sln" | head -n 1)

                                            if [ -z "\$sln" ]; then
                                                echo "❌ No solution found in ${serviceName}"
                                                exit 1
                                            fi

                                            echo "📦 Restoring: \$sln"

                                            # مهم جدًا لحل مشكلة assets.json
                                            dotnet restore "\$sln" \
                                                --packages /nuget-cache \
                                                --disable-parallel
                                        """
                                    }
                                }

                                parallel restoreSteps
                                groupIndex++
                            }
                        }

                        echo "🎉 All services restored successfully!"
                    }
                }
            }
        }


