pipeline{
    agent none

    environment {
        DOCKERHUB = credentials('Docker_Hub_Backend')          // credentials من Jenkins (username/password)
        SONAR_TOKEN = credentials('sonarCloud')  // token SonarQube
        IMAGE_NAME = "redasaad1234/backend"
        TAG = "latest"
        SERVICES_DIR = "Pipeline_Backend/Microservices"  // Updated path
        }

    stages {

        
        stage("checkout Source code") {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: git
                        image: alpine/git:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('git') {
                    script {
                        // Check if already in DevOps repo or need to checkout Backend
                        if (fileExists('Pipeline_Backend')) {
                            echo "✅ Already in DevOps repo structure, using Pipeline_Backend/Microservices"
                        } else {
                            echo "📦 Cloning Backend repository..."
                            sh 'rm -rf * .git || true'
                            git branch: 'main', url: 'https://github.com/RecoMind-Company/RecoMind-Backend.git', credentialsId: 'Git_hub'
                        }
                    }
                }
            }
        }
        stage('Discover Microservices') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    script {
                        // Debug: List what's in the workspace
                        sh "echo '📁 Contents of workspace:' && pwd && ls -la"
                        
                        // Try to find microservices in different possible locations
                        def servicesPath = ''
                        sh """
                            if [ -d "${SERVICES_DIR}" ]; then
                                echo "✅ Found services at: ${SERVICES_DIR}"
                            elif [ -d "Pipeline_Backend/Microservices" ]; then
                                echo "✅ Found services at: Pipeline_Backend/Microservices"
                            elif [ -d "Microservices" ]; then
                                echo "✅ Found services at: Microservices"
                            else
                                echo "❌ Microservices directory not found!"
                                echo "Looking for any 'Microservices' folder:"
                                find . -type d -name "Microservices" 2>/dev/null || echo "None found"
                                exit 1
                            fi
                        """
                        
                        // Discover services
                        services = sh(
                            script: """
                                if [ -d "${SERVICES_DIR}" ]; then
                                    ls -d ${SERVICES_DIR}/*/ 2>/dev/null | xargs -n 1 basename || echo ''
                                elif [ -d "Pipeline_Backend/Microservices" ]; then
                                    ls -d Pipeline_Backend/Microservices/*/ 2>/dev/null | xargs -n 1 basename || echo ''
                                else
                                    ls -d Microservices/*/ 2>/dev/null | xargs -n 1 basename || echo ''
                                fi
                            """,
                            returnStdout: true
                        ).trim().split("\n").findAll { it != '' && !it.contains("No such") }

                        if (services.isEmpty() || services[0] == '') {
                            echo "⚠️ No services found!"
                            services = []
                        } else {
                            echo "🔍 Found ${services.size()} services: ${services}"
                        }
                    }
                }
            }
        }


        stage("Restore"){
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: dotnet
                        image: mcr.microsoft.com/dotnet/sdk:8.0
                        command:
                        - cat
                        tty: true
                    """
                }
            }

            steps {
                container('dotnet') {
                    script {
                        int maxParallel = 3  // الحد الأقصى لعدد restores متوازية
                        def serviceList = services.toList()  // تحويل Array إلى List
                        def chunks = serviceList.collate(maxParallel)

                        int groupIndex = 1
                        for (chunk in chunks) {
                            echo "➡️ Restoring group ${groupIndex}/${chunks.size()} in parallel..."

                            def restoreSteps = [:]

                            for (service in chunk) {
                                def serviceName = service  // مهم داخل closure
                                restoreSteps["Restore ${serviceName}"] = {
                                    sh "dotnet restore ${SERVICES_DIR}/${serviceName} ."
                                    echo "✅ Restored: ${serviceName}"
                                }
                            }

                            parallel restoreSteps  // تشغيل المجموعة بشكل parallel
                            groupIndex++
                        }

                        echo "🎉 All services have been restored successfully!"
                    }
                }
            }
        }



        stage("Build"){
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: dotnet
                        image: mcr.microsoft.com/dotnet/sdk:8.0
                        command:
                        - cat
                        tty: true
                    """
                }
            }

            steps {
                container('dotnet') {
                    script {
                        int maxParallel = 3  // الحد الأقصى لعدد builds متوازية
                        def serviceList = services.toList()  // تحويل Array إلى List
                        def chunks = serviceList.collate(maxParallel)

                        int groupIndex = 1
                        for (chunk in chunks) {
                            echo "➡️ Building group ${groupIndex}/${chunks.size()} in parallel..."

                            def buildSteps = [:]

                            for (service in chunk) {
                                def serviceName = service  // مهم داخل closure
                                buildSteps["Build ${serviceName}"] = {
                                    sh "dotnet build ${SERVICES_DIR}/${serviceName} . -c Release --no-restore"
                                    echo "✅ Built: ${serviceName}"
                                }
                            }

                            parallel buildSteps  // تشغيل المجموعة بشكل parallel
                            groupIndex++
                        }

                        echo "🎉 All services have been built successfully!"
                    }
                }
            }
        }

        


        stage('OWASP Dependency Check') {

            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: dependency-check
                        image: owasp/dependency-check:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('dependency-check') {
                    script {
                    def reportDir = 'dependency-report'
                    sh "mkdir -p ${reportDir}"

                    int maxParallel = 2  // الحد الأقصى لعدد scans متوازية (أقل من Restore/Build لأنها ثقيلة)
                    def serviceList = services.toList()  // تحويل Array إلى List
                    def chunks = serviceList.collate(maxParallel)

                    int groupIndex = 1
                    for (chunk in chunks) {
                        echo "➡️ Scanning group ${groupIndex}/${chunks.size()} in parallel..."

                        def scanSteps = [:]

                        for (service in chunk) {
                            def serviceName = service  // مهم داخل closure
                            scanSteps["Scan ${serviceName}"] = {
                                def servicePath = "${SERVICES_DIR}/${serviceName}"
                                def reportPath = "${reportDir}/dependency-check-${serviceName}.html"

                                echo "🔍 Running OWASP Dependency Check for ${serviceName}..."

                                sh """
                                    dependency-check.sh \
                                        --project ${serviceName} \
                                        --scan ${servicePath} \
                                        --format HTML \
                                        --out ${reportPath}
                                """

                                echo "📝 Report generated: ${reportPath}"
                            }
                        }

                        parallel scanSteps  // تشغيل المجموعة بشكل parallel
                        groupIndex++
                    }

                    echo "🎉 All OWASP Dependency Checks completed successfully!"
                    }
                
            
                }
            }
        }

        stage('Archive Dependency Report') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    archiveArtifacts artifacts: 'dependency-report/**', allowEmptyArchive: true
                }
            }
        }


        stage('SonarQube Analysis') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: dotnet
                        image: mcr.microsoft.com/dotnet/sdk:8.0
                        command:
                        - cat
                        tty: true
                      - name: java
                        image: eclipse-temurin:17-jdk
                        command: ["cat"]
                        tty: true 
                    """
                }
            }
            steps {
                container('dotnet') {
                    script {
                        int maxParallel = 2  // الحد الأقصى لعدد analyses متوازية (أقل من Restore/Build لأنها ثقيلة)
                        def serviceList = services.toList()  // تحويل Array إلى List
                        def chunks = serviceList.collate(maxParallel)

                        int groupIndex = 1
                        for (chunk in chunks) {
                            echo "➡️ Analyzing group ${groupIndex}/${chunks.size()} in parallel..."

                            def analysisSteps = [:]

                            for (service in chunk) {
                                def serviceName = service  // مهم داخل closure
                                analysisSteps["Analyze ${serviceName}"] = {
                                    sh """
                                        dotnet tool install --global dotnet-sonarscanner || true

                                        dotnet sonarscanner begin \
                                        /k:"${serviceName}" \
                                        /o:"RecoMind Company" \
                                        /d:sonar.host.url="https://sonarcloud.io" \
                                        /d:sonar.token="$SONAR_TOKEN"

                                        dotnet build ${SERVICES_DIR}/${serviceName}

                                        dotnet sonarscanner end \
                                        /d:sonar.token="$SONAR_TOKEN"


                                    """
                                    echo "✅ SonarQube analysis completed for: ${serviceName}"
                                }
                            }

                            parallel analysisSteps  // تشغيل المجموعة بشكل parallel
                            groupIndex++
                        }

                        echo "🎉 All SonarQube analyses completed successfully!"
                    }
                }
            }
        }


        stage('Achieve Services List') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    writeFile file: 'services.txt', text: services.join('\n')
                    archiveArtifacts artifacts: 'services.txt', allowEmptyArchive: true
                }
            }
        }


        stage("Build & Push Docker (Kaniko)")
        {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: kaniko
                        image: gcr.io/kaniko-project/executor:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }

            steps {
                container('kaniko') {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        script {
                            // إعداد ملف config.json لتخزين بيانات اعتماد DockerHub
                            sh '''
                                mkdir -p /kaniko/.docker
                                echo "{\"auths\":{\"https://index.docker.io/v1/\":{\"username\":\"${DOCKERHUB_USR}\",\"password\":\"${DOCKERHUB_PSW}\"}}}" > /kaniko/.docker/config.json
                            '''

                            int maxParallel = 3  // الحد الأقصى لعدد builds متوازية
                            def serviceList = services.toList()  // تحويل Array إلى List
                            def chunks = serviceList.collate(maxParallel)

                            int groupIndex = 1
                            for (chunk in chunks) {
                                echo "➡️ Building & Pushing group ${groupIndex}/${chunks.size()} in parallel..."

                                def kanikoSteps = [:]

                                for (service in chunk) {
                                    def serviceName = service  // مهم داخل closure
                                    kanikoSteps["Build & Push ${serviceName}"] = {
                                        def imageTag = "${IMAGE_NAME}-${serviceName.toLowerCase()}:${TAG}"
                                        echo "🚀 Building and pushing: ${imageTag}"

                                        sh """
                                            /kaniko/executor \
                                                --dockerfile ${SERVICES_DIR}/${serviceName}/Dockerfile \
                                                --context ${SERVICES_DIR}/${serviceName} \
                                                --destination ${imageTag} \
                                                --cache=true \
                                                --cache-repo=${IMAGE_NAME}:cache
                                        """

                                        echo "✅ Built and pushed: ${imageTag}"
                                    }
                                }

                                parallel kanikoSteps  // تشغيل المجموعة بشكل parallel
                                groupIndex++
                            }

                            echo "🎉 All Docker images have been built and pushed successfully with Kaniko!"
                        }
                    }
                }
            }
        }



        stage('Prepare Trivy Template') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    sh '''
                        mkdir -p trivy-templates
                        wget -q https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -O trivy-templates/html.tpl
                    '''
                }
            }
        }

        stage('Trivy Security Scan') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: trivy
                        image: aquasec/trivy:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }

            steps {
                container('trivy') {
                    script {
                        int maxParallel = 2  // الحد الأقصى لعدد scans متوازية
                        def serviceList = services.toList()  // تحويل Array إلى List
                        def chunks = serviceList.collate(maxParallel)

                        int groupIndex = 1
                        for (chunk in chunks) {
                            echo "➡️ Scanning group ${groupIndex}/${chunks.size()} in parallel..."

                            def trivySteps = [:]

                            for (service in chunk) {
                                def serviceName = service  // مهم داخل closure
                                trivySteps["Scan ${serviceName}"] = {
                                    def imageTag = "${IMAGE_NAME}-${serviceName.toLowerCase()}:${TAG}"
                                    def reportName = "trivy-${serviceName}.html"

                                    echo "🔍 Scanning image: ${imageTag}"

                                    sh """
                                        trivy image \
                                            --scanners vuln \
                                            --severity HIGH,CRITICAL \
                                            --timeout 20m \
                                            --exit-code 0 \
                                            --format template \
                                            --template trivy-templates/html.tpl \
                                            -o ${reportName} \
                                            ${imageTag}
                                    """

                                    echo "📝 Report generated: ${reportName}"
                                }
                            }

                            parallel trivySteps  // تشغيل المجموعة بشكل parallel
                            groupIndex++
                        }

                        archiveArtifacts artifacts: "trivy-*.html", allowEmptyArchive: true
                        echo "🎉 All Trivy security scans completed successfully!"
                    }
                }
            }
        }



        stage('Trigger CD Pipeline') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: shell
                        image: alpine:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('shell') {
                    build job: "Pipeline_Backend_cd", wait: false
                }
            }
        }

    }
}



