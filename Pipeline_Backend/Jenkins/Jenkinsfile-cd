pipeline{
    agent any

    environment {
        DOCKERHUB = credentials('Docker_Hub_Backend')          // credentials من Jenkins (username/password)
        IMAGE_NAME = "redasaad1234/backend"
        TAG = "latest"

    }

    stages{
        stage("checkout Source code") {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: git
                        image: alpine/git:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('git') {
                    git branch: 'main', url: 'https://github.com/RecoMind-Company/RecoMind-Backend.git' , credentialsId: 'Git_hub'
                    stash name: 'source', includes: '**/*'
                }
                   
               
            }
        }

        stage("Create the secrets for pull image in Helm chart ") {
            steps {
                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', passwordVariable: 'DOCKERHUB_PSW', usernameVariable: 'DOCKERHUB_USR')]) {
                    sh '''
                        echo "Creating Kubernetes secret for Docker Hub authentication..."
                        kubectl create secret docker-registry dockerhub-secret \
                        --docker-server=https://index.docker.io/v1/ \
                        --docker-username=$DOCKERHUB_USR \
                        --docker-password=$DOCKERHUB_PSW \
                        --docker-email=redasaad010260@gamil.com \
                        --namespace=default \
                        --dry-run=client -o yaml | kubectl apply -f -
                    '''
                }
            }
        }


        stage("Deploy to Kubernetes with Helm") {
            steps {
                unstash 'source'
                sh '''
                    echo "Deploying application to Kubernetes using Helm..."
                    helm upgrade --install recomind ./Helm/Platform --namespace default
                '''
            }
        }
    }




}  

