pipeline{
    agent any

    environment {
        DOCKERHUB = credentials('Docker_Hub_Backend')          // credentials من Jenkins (username/password)
        IMAGE_NAME = "redasaad1234/backend"
        TAG = "latest"

        AZURE_TENANT_ID       = credentials('TENANT_ID')
        AZURE_CLIENT_ID       = credentials('CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('CLIENT_SECRET')

    }

    stages{
        stage("checkout Source code") {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: git
                        image: alpine/git:latest
                        command:
                        - cat
                        tty: true
                    """
                }
            }
            steps {
                container('git') {
                    git branch: 'main', url: 'https://github.com/RecoMind-Company/RecoMind-Backend.git' , credentialsId: 'Git_hub'
                    stash name: 'source', includes: '**/*'
                }
                   
               
            }
        }

        stage("Create the secrets for pull image in Helm chart ") {
            steps {
                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', passwordVariable: 'DOCKERHUB_PSW', usernameVariable: 'DOCKERHUB_USR')]) {
                    sh '''
                        az aks get-credentials \
                        --resource-group aks-rg-Recomind \
                        --name Recomind-aks \
                        --overwrite-existing

                        kubectl get nodes

                        echo "Creating secret..."
                        kubectl create secret docker-registry dockerhub-secret \
                        --docker-server=https://index.docker.io/v1/ \
                        --docker-username=$DOCKERHUB_USR \
                        --docker-password=$DOCKERHUB_PSW \
                        --docker-email=redasaad010260@gamil.com \
                        --namespace=default \
                        --dry-run=client -o yaml | kubectl apply -f -

                        kubectl get secret dockerhub-secret -n default
                    '''
                }
            }
        }


        stage("Deploy to Kubernetes with Helm") {
            steps {
                unstash 'source'
                sh '''
                    set -e

                    cd Pipeline_Backend

                    echo "🔐 Logging into Azure..."
                    az login --service-principal \
                    -u $AZURE_CLIENT_ID \
                    -p $AZURE_CLIENT_SECRET \
                    --tenant $AZURE_TENANT_ID

                    echo "🔗 Connecting to AKS..."
                    az aks get-credentials \
                    --resource-group aks-rg-Recomind \
                    --name Recomind-aks \
                    --overwrite-existing

                    echo "📡 Verifying cluster..."
                    kubectl get nodes
                    kubectl get clusterissuer letsencrypt-prod

                    echo "🚀 Deploying application using Helm..."
                    helm upgrade --install recomind ./Helm/Platform \
                    --namespace default
                '''
            }
        }
    }




}  

