
pipeline {
    agent any

    parameters {

        string(
            name: 'MANUAL_PUBLIC_IP',
            defaultValue: '',
            description: 'Provide IP to run Ansible manually and skip Terraform'
        )

        booleanParam(
            name: 'SKIP_ANSIBLE', 
            defaultValue: false, 
            description: 'Skip Ansible and run Terraform only'
        )
    }

    environment { 
        ARM_CLIENT_ID       = credentials('CLIENT_ID')
        ARM_CLIENT_SECRET   = credentials('CLIENT_SECRET')
        ARM_SUBSCRIPTION_ID = credentials('SUBSCRIPTION_ID')
        ARM_TENANT_ID       = credentials('TENANT_ID')

        TF_VAR_ssh_public_key   = credentials('SSH_PUBLIC_KEY')
        TF_VAR_subscription_id  = credentials('SUBSCRIPTION_ID')
        TF_VAR_tenant_id        = credentials('TENANT_ID')
        TF_VAR_client_id        = credentials('CLIENT_ID')
        TF_VAR_client_secret    = credentials('CLIENT_SECRET')
        private_key  = credentials('SSH_Privete_KEY')
        ipToUse = ""
    }

    stages {
       


        stage('Terraform Init') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }

            steps {
                dir('Terraform/Terraform_AIVmServer') {
                    sh 'rm -rf .terraform .terraform.lock.hcl'
                    sh 'terraform init -reconfigure'
                }
            }
        }



        stage('Terraform Validate') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }
            steps {
                dir('Terraform/Terraform_AIVmServer') {
                    sh 'terraform validate'
                }
            }
        }

        stage('ssh-keyscan') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }
            
            steps {
                dir('Terraform/Terraform_AIVmServer') {
                    sh '''
                    mkdir -p ~/.ssh
                    echo "${TF_VAR_ssh_public_key}" > ~/.ssh/id_rsa.pub
                    echo "${private_key}" > ~/.ssh/id_rsa
                    chmod 600 ~/.ssh/id_rsa
                    chmod 644 ~/.ssh/id_rsa.pub
                    '''
                }
            }
        }

        stage('Terraform Plan') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }
            steps {
                dir('Terraform/Terraform_AIVmServer') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Terraform Apply') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }
            steps {
                dir('Terraform/Terraform_AIVmServer') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Get Public IP') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }
            steps {
                dir('Terraform/Terraform_AIVmServer') {
                    script {
                        env.PUBLIC_IP = sh(script: "terraform output -raw public_ip", returnStdout: true).trim()
                        echo "Public IP is: ${env.PUBLIC_IP}"
                        writeFile file: 'outputs/server_ip.txt', text: env.PUBLIC_IP
                    }
                }
            }
        }

        stage('Archive Outputs') {
            when{
                expression { return !params.MANUAL_PUBLIC_IP } 
            }


            steps {
                archiveArtifacts artifacts: 'Terraform/Terraform_AIVmServer/outputs/server_ip.txt', fingerprint: true
            }
        }

        stage('Run Ansible') {
            steps {
               
                dir('ansible') {
                    script {
                        def ipToUse = env.PUBLIC_IP ?: params.MANUAL_PUBLIC_IP
                        if (!ipToUse) {
                            error "No PUBLIC_IP available! Set MANUAL_PUBLIC_IP for manual run."
                        }
                        echo "Running Ansible on IP: ${ipToUse}"
                        // sh "ansible-playbook  SetupVmPlaybook.yml -i ${ipToUse},"
                    }
                }                  
            }
        }

        // stage('install Ansible') {
        //     steps {
        //         sh '''
        //         sudo apt update
        //         sudo apt install ansible -y
        //         ansible --version
        //         '''
        //     }
        // }

        stage('ssh connect'){
            steps {
                sh '''
                ssh -o StrictHostKeyChecking=no -i ~/.ssh/id_rsa AI_Server@${ipToUse} "echo Connected successfully"
                '''
            }
        }

        stage('create Ansible inventory file'){
            steps {
                sh '''
                cat > ansible_inventory.ini << EOL
                [all]
                server ansible_host=${ipToUse} ansible_ssh_user=AI_Server ansible_ssh_private_key_file=~/.ssh/id_rsa

                cat ansible_inventory.ini
                EOL
                '''
            }
        }

        stage('run Ansible Playbook'){
            steps {
                sh '''
                ansible-playbook -i ansible_inventory.ini SetupVmPlaybook.yml
                '''
            }
        }


        stage('Test connectivity to AI Server'){
            steps {
                sh '''
                ansible -i ansible_inventory.ini all -m ping
                '''
            }
        }



        
    }
}













