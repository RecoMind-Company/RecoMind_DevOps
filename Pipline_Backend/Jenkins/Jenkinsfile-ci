pipeline{
    agent any

    environment {
        DOCKERHUB = credentials('Docker_Hub_Backend')          // credentials من Jenkins (username/password)
        // SONAR_AUTH_TOKEN = credentials('SonarQube_jenkins') // token SonarQube
        IMAGE_NAME = "redasaad1234/backend"
        TAG = "latest"
        SERVICES_DIR = "Microservices"
        }

    stages {
        
        stage("checkout Source code") {
            steps {
                git branch: 'main', url: 'https://github.com/RecoMind-Company/RecoMind-Backend.git' , credentialsId: 'Git_hub'
            }
        }


        stage('OWASP Dependency Check') {
            steps {
                sh 'mkdir -p dependency-check-report'
                // استخدام Plugin بدلاً من CLI
                dependencyCheck additionalArguments: '--scan . --format XML --out dependency-report',
                                odcInstallation: 'OWASP-Dependency'
            }
        }

        stage('Archive Dependency Report') {
            steps {
                archiveArtifacts artifacts: 'dependency-report/**', allowEmptyArchive: true
            }
        }


        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'SonarQube_Scanner'
                    
                    withSonarQubeEnv('SonarCloud_Server') {
                        withCredentials([string(credentialsId: 'sonarCloud', variable: 'TOKEN')]) {
                            sh """
                                ${scannerHome}/bin/sonar-scanner \
                                -Dsonar.projectKey=recomind-backend \
                                -Dsonar.organization=recomind-company \
                                -Dsonar.host.url=https://sonarcloud.io \
                                -Dsonar.sources=. \
                                -Dsonar.login="${TOKEN}"
                            """
                        }
                    }
                }
            }
        }

        stage('Discover Microservices') {
            steps {
                    script {
                    services = sh(
                        script: "ls -d ${SERVICES_DIR}/*/ | xargs -n 1 basename",
                        returnStdout: true
                    ).trim().split("\n")

                    echo "🔍 Found services: ${services}"
                }

            }
        }

        stage('Achieve Services List') {
            steps {
                writeFile file: 'services.txt', text: services.join('\n')
                archiveArtifacts artifacts: 'services.txt', allowEmptyArchive: true
            }
        }


        stage('Build Docker Image') {
            steps {
                script {
                    for (service in services) {
                        def imageTag = "${IMAGE_NAME}-${service.toLowerCase()}:${TAG}"
                        sh """
                            docker build  -t ${imageTag} ${SERVICES_DIR}/${service}
                        """
                        echo "🛠️ Built image: ${imageTag}"
                    }
                }
                
            }
        }

        stage('Prepare Trivy Template') {
            steps {
                sh '''
                    mkdir -p trivy-templates
                    wget -q https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -O trivy-templates/html.tpl
                '''
            }
        }

        
        stage('Trivy Security Scan') {
            steps {
                script {
                    for (service in services) {

                        def imageTag = "${IMAGE_NAME}-${service.toLowerCase()}:${TAG}"
                        def reportName = "trivy-${service}.html"

                        echo "🔍 Scanning image: ${imageTag}"

                        sh """
                            trivy image \
                                --scanners vuln \
                                --severity HIGH,CRITICAL \
                                --timeout 20m \
                                --exit-code 0 \
                                --format template \
                                --template trivy-templates/html.tpl \
                                -o ${reportName} \
                                ${imageTag}
                        """

                        echo "📝 Report generated: ${reportName}"
                    }

                    archiveArtifacts artifacts: "trivy-*.html", allowEmptyArchive: true
                }
            }
        }

        stage('DockerHub Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                }
            }
        }


        stage('Push Docker Images') {
            steps {
                script {
                    int maxParallel = 3  // الحد الأقصى لعدد pushes متوازية
                    def serviceList = services.toList()  // تحويل Array إلى List
                    def chunks = serviceList.collate(maxParallel)

                    int groupIndex = 1
                    for (chunk in chunks) {
                        echo "➡️ Pushing group ${groupIndex}/${chunks.size()} in parallel..."

                        def pushSteps = [:]

                        for (service in chunk) {
                            def serviceName = service  // مهم داخل closure
                            pushSteps["Push ${serviceName}"] = {
                                // تسجيل الدخول داخل كل push step
                                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Backend', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"

                                    def imageTag = "${IMAGE_NAME}-${serviceName.toLowerCase()}:${TAG}"
                                    echo "⏳ Pushing image: ${imageTag}"
                                    sh "docker push ${imageTag}"
                                    echo "✅ Pushed image: ${imageTag}"
                                }
                            }
                        }

                        parallel pushSteps  // تشغيل المجموعة بشكل parallel
                        groupIndex++
                    }

                    echo "🎉 All Docker images have been pushed successfully!"
                }
            }
        }


        stage('Trigger CD Pipeline') {
            steps {
                build job: "Pipeline_Backend_cd", wait: false
            }
        }

    }
}



