{% for service in active_services %}
{% if service.expose_to_nginx %}
# Upstream for {{ service.name }}
upstream {{ service.name }}_backend {
    server 127.0.0.1:{{ service.port }};
    keepalive 32;
}

{% endif %}
{% endfor %}

# HTTP server ONLY
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain_name }};


    root /var/www/certbot;

    # Serve ACME challenge files directly
    location /.well-known/acme-challenge/ {
        alias /var/www/certbot/.well-known/acme-challenge/;
    }

    access_log /var/log/nginx/{{ domain_name }}_access.log;
    error_log /var/log/nginx/{{ domain_name }}_error.log;

    client_max_body_size 50M;

{% for service in active_services %}
{% if service.expose_to_nginx %}
    # {{ service.name }} service
    location {{ service.nginx_path }}/ {
        proxy_pass http://{{ service.name }}_backend/{{service.nginx_path}}/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        sub_filter_once off;

        sub_filter '"./swagger' '"/{{ service.nginx_path }}/swagger';
        sub_filter "'./swagger" "'/{{ service.nginx_path }}/swagger";

        sub_filter 'href="/swagger' 'href="/{{ service.nginx_path }}/swagger/';
        sub_filter 'src="/swagger' 'src="/{{ service.nginx_path }}/swagger/';

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

{% endif %}
{% endfor %}

    location = / {
        add_header Content-Type application/json;
        return 200 '{"status":"ok","services":[{% for s in active_services %}{% if s.expose_to_nginx %}"{{ s.name }}"{% if not loop.last %},{% endif %}{% endif %}{% endfor %}]}';
    }
}
