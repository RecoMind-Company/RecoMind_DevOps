
server {
    listen 80;
    server_name {{ server_domain_or_IP }};

    # Static files for Reporting System
    location /reporting/static/ {
        alias /var/www/{{ reporting_container_name }};
    }

    # Reporting System API
    location /reporting/ {
        proxy_pass http://127.0.0.1:{{ reporting_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection keep-alive;
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    # Data Embedding Static files
    location /embedding/static/ {
        alias /var/www/{{ embedding_container_name }};
    }

    # Data Embedding API
    location /embedding/ {
        proxy_pass http://127.0.0.1:{{ embedding_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection keep-alive;
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Forwarded-Prefix /embedding; # يجب التأكد من وجود هذا
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;

    }

    # Redirect root
    location / {
        return 301 /reporting/;
    }
}




