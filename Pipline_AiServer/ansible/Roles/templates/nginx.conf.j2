
server {
    listen 80;
    server_name {{ server_domain_or_IP }};

    # --- Reporting System ---

    # Reporting System Static files
    location /reporting/static/ {
            root /var/www/{{ reporting_container_name }};
    }

    # Reporting System: Handle openapi.json file
    # هذا يحل مشكلة "Failed to load API definition"
    location /reporting/openapi.json {
        # يتم توجيه الطلب إلى التطبيق الخلفي دون إضافة الشرطة المائلة الأخيرة (/) 
        # لضمان وصول المسار كاملاً إلى التطبيق: /openapi.json
        proxy_pass http://127.0.0.1:{{ reporting_port }}; 
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection keep-alive;
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }


    location /reporting/ {
            # الشرطة المائلة (/) لحذف البادئة /reporting/ قبل التمرير
            proxy_pass http://127.0.0.1:{{ reporting_port }}/;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection keep-alive;
            proxy_set_header Host $host;
            proxy_cache_bypass $http_upgrade;
    }

    # --- Data Embedding System ---

    # Data Embedding Static files
    location /embedding/static/ {
            root /var/www/{{ embedding_container_name }};
    }

    # Data Embedding API
    location /embedding/ {

            proxy_pass http://127.0.0.1:{{ embedding_port }}/; 
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection keep-alive;
            proxy_set_header Host $host;
            proxy_cache_bypass $http_upgrade;
    }

    # --- Root Redirection ---
    location / {
            return 301 /reporting/;
    }
}