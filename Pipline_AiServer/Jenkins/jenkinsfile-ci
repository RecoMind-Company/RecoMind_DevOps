pipeline {
    agent any

    environment {
        DOCKERHUB = credentials('Docker_Hub_Hossam')          // credentials من Jenkins (username/password)
        SONAR_AUTH_TOKEN = credentials('SonarQube_jenkins') // token SonarQube
        IMAGE_NAME = "hossamtaha9/recomind-ai-vector"
        TAG = "latest"
    }

    stages {

        stage('Clean Conflicting Refs') {
            steps {
                sh '''
                    #!/bin/bash
                    set -e
                    cd /var/lib/jenkins/workspace/Pipline-Ai-ci/
                    
                    # Remove the conflicting reference
                    if [ -d . git/refs/remotes/origin/feature/chatbot ]; then
                        rm -rf .git/refs/remotes/origin/feature/chatbot
                        echo "✓ Removed conflicting chatbot ref"
                    else
                        echo "✓ No conflicting ref found"
                    fi
                    
                    # Also clean packed-refs if needed
                    if [ -f . git/packed-refs ]; then
                        sed -i '/refs\\/remotes\\/origin\\/feature\\/chatbot$/d' .git/packed-refs
                        echo "✓ Cleaned packed-refs"
                    fi
                '''
            }
        }


        

        stage('Checkout Source Code') {
            steps {
                sh """
                    cd /var/lib/jenkins/workspace/Pipline-Ai-ci/
                    git remote prune origin
                """
                // checkout للكود من repo الرئيسي
                git branch: 'main', url: 'https://github.com/RecoMind-Company/RecoMind-AI.git', credentialsId: 'Git_hub'
            }
        }

        stage('Archive Outputs') {
            steps {
                archiveArtifacts artifacts: 'src/data_embedding/docker-compose.yml', fingerprint: true
            }
        }



        

        stage('OWASP Dependency Check') {
            steps {
                sh 'mkdir -p dependency-check-report'
                // استخدام Plugin بدلاً من CLI
                dependencyCheck additionalArguments: '--scan . --format XML --out dependency-report',
                                odcInstallation: 'OWASP-Dependency' // الاسم اللي اخترته في Jenkins
            }
        }

        stage('Archive Dependency Report') {
            steps {
                archiveArtifacts artifacts: 'dependency-report/**', allowEmptyArchive: true
            }
        }

        stage('SonarQube Scan') {
            steps {
                script {
                    def scannerHome = tool 'SonarQube_Scanner'
                    
                    withSonarQubeEnv('SonarCloud_Server') {
                        withCredentials([string(credentialsId: 'sonarCloud', variable: 'TOKEN')]) {
                            sh """
                                ${scannerHome}/bin/sonar-scanner \
                                -Dsonar.projectKey=recomind-company-Ai \
                                -Dsonar.organization=recomind-company \
                                -Dsonar.host.url=https://sonarcloud.io \
                                -Dsonar.sources=. \
                                -Dsonar.login=$TOKEN
                            """
                        }
                    }
                }
            }
        }

        // stage('Quality Gate') {
        //     steps {
        //         timeout(time: 15, unit: 'MINUTES') {
        //             // ✅ الآن هيشتغل صح لأن الـ scan كان جوا withSonarQubeEnv
        //             waitForQualityGate abortPipeline: true
        //         }
        //     }
        // }

        stage("Build Docker Image") {
            parallel {
                stage('Build data_embedding Image') {
                    steps {
                        dir('src/data_embedding') {
                            sh "docker build -t ${IMAGE_NAME}-data_embedding:${TAG} ."
                        }
                    }
                }

                stage('Build reporting_system Image') {
                    steps {
                        dir('src/reporting_system') {
                            sh "docker build -t ${IMAGE_NAME}-reporting_system:${TAG} ."
                        }
                    }
                }

                stage('Build copilot Image') {
                    steps {
                        dir('src/copilot') {
                            sh "docker build -t ${IMAGE_NAME}-copilot:${TAG} ."
                        }
                    }
                }
            }
        }

        stage('Trivy Security Scan') {
            steps {
                sh """
                    trivy image --scanners vuln --light  --timeout 20m  --exit-code 0 --severity HIGH,CRITICAL $IMAGE_NAME-reporting_system:$TAG
                    trivy image --scanners vuln --light --timeout 20m  --exit-code 0 --severity HIGH,CRITICAL $IMAGE_NAME-data_embedding:$TAG
                    trivy image --scanners vuln --light --timeout 20m  --exit-code 0 --severity HIGH,CRITICAL $IMAGE_NAME-copilot:$TAG
                """
            }
        }

        stage('DockerHub Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'Docker_Hub_Hossam', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                }
            }
        }

        stage('Push Image') {
            parallel{
                stage('Push data_embedding Image') {
                    steps {
                        sh "docker push ${IMAGE_NAME}-data_embedding:$TAG"
                    }
                }

                stage('Push reporting_system Image') {
                    steps {
                        sh "docker push ${IMAGE_NAME}-reporting_system:$TAG"
                    }
                }

                stage('Push copilot Image') {
                    steps {
                        sh "docker push ${IMAGE_NAME}-copilot:$TAG"
                    }
                }
            }
        }

        


        

        stage('Trigger CD Pipeline') {
            steps {
                build job: "Pipline-Ai-cd", wait: false
            }
        }
    }

    post {
        always {
            echo "Pipeline finished. Reports saved."
        }
        success {
            echo "✅ Pipeline completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed. Check the logs."
        }
    }
}