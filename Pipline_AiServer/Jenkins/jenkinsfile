pipeline {
    agent any

    environment {
        DOCKERHUB = credentials('Docker')          // credentials من Jenkins (username/password)
        SONAR_AUTH_TOKEN = credentials('SonarQube_jenkins') // token SonarQube
        IMAGE_NAME = "hossamtaha9/recomind-ai-vector"
        TAG = "latest"
    }

    stages {

        stage('Checkout Source Code') {
            steps {
                // checkout للكود من repo الرئيسي
                git branch: 'main', url: 'https://github.com/RecoMind-Company/RecoMind-AI.git' , credentialsId: 'Github'
            }
        }

        stage('OWASP Dependency Check') {
            steps {

                sh'mkdir -p dependency-check-report'
                // استخدام Plugin بدلاً من CLI
                dependencyCheck additionalArguments: '--scan . --format XML --out dependency-report',
                                odcInstallation: 'OWASP-Dependency' // الاسم اللي اخترته في Jenkins
            }
        }

        stage('Archive Dependency Report') {
            steps {
                archiveArtifacts artifacts: 'dependency-report/**', allowEmptyArchive: true
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('SonarQube_Server') {
                    def scannerHome = tool 'SonarQube_Scanner'
                    sh """
                        sonar-scanner \
                        -Dsonar.projectKey=data_embedding \
                        -Dsonar.sources=. \
                        -Dsonar.host.url=http://172.30.100.44:9000 \
                        -Dsonar.login=${SONAR_AUTH_TOKEN}
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 2, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline failed due to Quality Gate: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage("Build Docker Image") {
            steps {
                sh "docker build -t $IMAGE_NAME:$TAG ."
            }
        }

        stage('Trivy Security Scan') {
            steps {
                sh """
                    trivy image --exit-code 0 --severity HIGH,CRITICAL $IMAGE_NAME:$TAG
                """
            }
        }

        stage('DockerHub Login') {
            steps {
                sh "echo $DOCKERHUB_PSW | docker login -u $DOCKERHUB_USR --password-stdin"
            }
        }

        stage('Push Image') {
            steps {
                sh "docker push $IMAGE_NAME:$TAG"
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                build job: "CD_Job_Name", wait: false
            }
        }
    }

    post {
        always {
            // archive أي ملفات أخرى لو تحب
            echo "Pipeline finished. Reports saved."
        }
    }
}
