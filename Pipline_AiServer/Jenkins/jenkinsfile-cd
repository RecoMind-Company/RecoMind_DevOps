pipeline{
    agent any

    environment {
        DOCKERHUB = credentials('Docker_Hub_Hossam')          // credentials من Jenkins (username/password)
        IMAGE_NAME = "hossamtaha9/recomind-ai-vector"
        TAG = "latest"

    }

    

    stages {
        stage('Get Artifacts from Pipeline Infrastructure') {
            steps {
                copyArtifacts(
                    projectName: 'Pipline_Infrastructure',
                    fingerprintArtifacts: true,
                    selector: lastSuccessful(stable: false)  // أو true حسب الحاجة
                )
            }
        }

        stage('Add Ip or Domain to Ansible Defaults') {
            steps {
                script {
                    def publicIp = readFile('Pipline_infrastructure/Terraform/Terraform_AIVmServer/outputs/server_ip.txt').trim()
                    sh 'sed -i "s/^server_domain_or_IP:.*$/server_domain_or_IP: \'$publicIp\'/" Pipline_AiServer/ansible/Roles/defaults/main.yml'
                }
            }
        }

        stage('Run Ansible Playbook') {
            steps {
                dir('Pipline_AiServer/ansible') {
                    sh 'ansible-playbook -i ansible_inventory.ini playbook-cd.yml '
                }
            }
        }

        stage('connect to Ai Server ') {
            
            steps {
                withCredentials([
                    sshUserPrivateKey(credentialsId: 'SSH_USER', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USER'),
                ]) {
                    script{
                        env.publicIp = readFile('Pipline_infrastructure/Terraform/Terraform_AIVmServer/outputs/server_ip.txt').trim()
                        env.server_name = readFile('Pipline_infrastructure/Terraform/Terraform_AIVmServer/outputs/server_Name.txt').trim()

                        sh '''
                        echo "Testing SSH connection to ${ipToUse}"
                        ssh -o StrictHostKeyChecking=no -i "$SSH_KEY_FILE" ${server_name}@${publicIp} "echo Connected successfully"
                        '''

                    }

                    
                }
            }

            
        }

        stage('pull Docker Image on AI Server') {
            steps {
                withCredentials([
                    sshUserPrivateKey(credentialsId: 'SSH_USER', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USER'),
                    usernamePassword(credentialsId: 'Docker_Hub_Hossam', usernameVariable: 'DOCKERHUB_USR', passwordVariable: 'DOCKERHUB_PSW')
                ]) {
                    sh '''

                    echo "Pulling Docker Image on AI Server"
                    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY_FILE" ${server_name}@${publicIp} "
                        docker login -u $DOCKERHUB_USR -p $DOCKERHUB_PSW &&
                        docker pull ${IMAGE_NAME}:${TAG} "
                    '''
                }
            }
        }

